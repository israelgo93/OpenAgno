{
	"$schema": "https://mintlify.com/docs.json",
	"theme": "mint",
	"name": "OpenAgno",
	"description": "Build and operate Agno-based agents with a declarative workspace, packaged CLI, multi-channel runtime, knowledge base, and MCP.",
	"colors": {
		"primary": "#6366F1",
		"light": "#818CF8",
		"dark": "#4F46E5"
	},
	"logo": {
		"light": "/logo/light.svg",
		"dark": "/logo/dark.svg"
	},
	"favicon": "/favicon.svg",
	"navbar": {
		"links": [
			{
				"label": "GitHub",
				"href": "https://github.com/OpenAgno/OpenAgno"
			}
		]
	},
	"navigation": {
		"languages": [
			{
				"language": "en",
				"default": true,
				"groups": [
					{
						"group": "Getting started",
						"pages": [
							"index",
							"quickstart",
							"getting-started-no-code",
							"architecture"
						]
					},
					{
						"group": "Workspace",
						"pages": [
							"workspace/overview",
							"workspace/config",
							"workspace/templates",
							"workspace/integrations",
							"models",
							"channels",
							"tools",
							"knowledge",
							"mcp"
						]
					},
					{
						"group": "Operations",
						"pages": [
							"cli",
							"studio",
							"api",
							"security",
							"troubleshooting"
						]
					},
					{
						"group": "Deployment",
						"pages": [
							"deployment",
							"structure"
						]
					},
					{
						"group": "Integrations",
						"pages": [
							"ide-integration",
							"whatsapp-cloud-api",
							"whatsapp-tunnel"
						]
					},
					{
						"group": "Reference",
						"pages": [
							"reference",
							"changelog"
						]
					}
				]
			},
			{
				"language": "es",
				"groups": [
					{
						"group": "Comenzando",
						"pages": [
							"es/index",
							"es/quickstart",
							"es/getting-started-no-code"
						]
					},
					{
						"group": "Runtime y workspace",
						"pages": [
							"es/channels",
							"es/mcp",
							"es/api",
							"es/whatsapp-tunnel"
						]
					},
					{
						"group": "Integraciones",
						"pages": [
							"es/ide-integration"
						]
					}
				]
			}
		]
	},
	"search": {
		"prompt": "Search commands, workspace, channels, knowledge, MCP, tenants, or deployment."
	},
	"footer": {
		"socials": {
			"github": "https://github.com/OpenAgno/OpenAgno"
		}
	}
}
