# ===================================
# OpenAgno - Variables de Entorno (v1.0.0)
# ===================================

# === API Keys ===
GOOGLE_API_KEY=
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# TAVILY_API_KEY=tvly-...

# === Seguridad API ===
# OPENAGNO_API_KEY=genera_con_openssl_rand_hex_32

# === Base de Datos (Supabase) ===
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=tu_password_seguro
DB_NAME=postgres
DB_SSLMODE=require

# === Base de Datos (Local - Docker) ===
# DB_HOST=localhost
# DB_PORT=5532
# DB_USER=ai
# DB_PASSWORD=ai
# DB_NAME=ai
# DB_SSLMODE=prefer

# === Docker Compose (credenciales via env vars) ===
# POSTGRES_DB=ai
# POSTGRES_USER=ai
# POSTGRES_PASSWORD=cambiame_en_produccion

# === WhatsApp (Meta Business API) ===
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_URL=https://tu-dominio.com/webhook

# === WhatsApp QR Bridge (modo qr_link/dual) ===
# BRIDGE_PORT=3001
# SESSION_DIR=./whatsapp_session
# GATEWAY_URL=http://localhost:8000

# === Slack (opcional) ===
# SLACK_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=tu_signing_secret

# === Telegram ===
# TELEGRAM_TOKEN=bot_token_from_botfather

# === Gmail (opcional) ===
# GMAIL_SENDER=tu_email@gmail.com
# GMAIL_PASSKEY=tu_app_password
# GMAIL_RECEIVER=default_receptor@email.com

# === GitHub (GithubTools) ===
# GITHUB_TOKEN=ghp_...

# === MCP (opcional) ===
# SUPABASE_ACCESS_TOKEN=

# === Remote Servers (F4) ===
# RESEARCH_PORT=7778

# === Seguridad OS ===
# OS_SECURITY_KEY=genera_con_openssl_rand_hex_32

# === AWS Bedrock ===
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1

# === Audio (STT/TTS via OpenAI) ===
# OPENAI_API_KEY ya se usa para embeddings; tambien sirve para Whisper y TTS.
# Configuracion en workspace/config.yaml seccion "audio:"
# FALLBACK_COOLDOWN_SECONDS=60  # Segundos antes de restaurar modelo primario

# === Entorno ===
APP_ENV=development

# Raiz absoluta del repo (ShellTools / runbook operativo). Si vacio, el loader usa la raiz por defecto.
OPENAGNO_ROOT=
